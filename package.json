{
  "name": "gutu-lib-telemetry-ui",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/telemetry-ui build",
    "typecheck": "bun run --cwd framework/libraries/telemetry-ui typecheck",
    "lint": "bun run --cwd framework/libraries/telemetry-ui lint",
    "test": "bun run --cwd framework/libraries/telemetry-ui test",
    "test:unit": "bun run --cwd framework/libraries/telemetry-ui test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
